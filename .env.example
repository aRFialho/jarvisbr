# API / Render / Neon
NODE_ENV=development
PORT=4000
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require
JWT_SECRET=troque-por-um-segredo-longo
DEVICE_TOKEN_SECRET=troque-por-outro-segredo-longo
CORS_ORIGIN=http://localhost:5173
CONFIRMATION_TTL_MINUTES=5
EXECUTION_TOKEN_TTL_MINUTES=5

# Web
VITE_API_URL=http://localhost:4000
NEXT_PUBLIC_API_URL=http://localhost:4000

# Agent Windows
JARVIS_API_URL=http://localhost:4000
JARVIS_DEVICE_TOKEN=cole-o-token-retornado-em-/devices/claim
JARVIS_ALLOWED_DIRS=C:\Users\seu-usuario\Downloads;C:\Users\seu-usuario\Pictures
JARVIS_AGENT_DATA_DIR=C:\Users\seu-usuario\.jarvis-agent
